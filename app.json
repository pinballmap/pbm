{
  "cron": [
    {
      "command": "rake send_weekly_digest_region",
      "schedule": "0 19 * * 5"
    },
    {
      "command": "rake send_weekly_digest_global",
      "schedule": "0 20 * * 5"
    },
    {
      "command": "rake send_daily_digest_region",
      "schedule": "0 9 * * *"
    },
    {
      "command": "rake send_daily_digest_global",
      "schedule": "0 8 * * *"
    },
    {
      "command": "rake send_daily_digest_operator_email",
      "schedule": "0 10 * * *"
    },
    {
      "command": "rake tag_opdb_changelog",
      "schedule": "30 13 * * *"
    },
    {
      "command": "rake tag_opdb_image",
      "schedule": "45 13 * * *"
    },
    {
      "command": "rake delete_opted_in_empty_locations",
      "schedule": "30 22 * * 0"
    },
    {
      "command": "rake data_cleanup",
      "schedule": "0 20 * * *"
    }
  ]
}
