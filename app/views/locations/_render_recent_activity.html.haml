.activity_filter
  %div
    =image_tag("icons/new_lmx.svg", :alt => "new_lmx", :class => 'activity_icon')
    %input{:type => "checkbox", :class => "loc_activity_filter m_0", :value => 'new_lmx'}
    %div
      %span Machine added
  %div
    =image_tag("icons/remove_machine.svg", :alt => "remove_machine", :class => 'activity_icon')
    %input{:type => "checkbox", :class => "loc_activity_filter m_0", :value => 'remove_machine'}
    %div
      %span Machine removed
  %div
    =image_tag("icons/new_condition.svg", :alt => "new_condition", :class => 'activity_icon')
    %input{:type => "checkbox", :class => "loc_activity_filter m_0", :value => 'new_condition'}
    %div
      %span New condition
  %div
    =image_tag("icons/new_msx.svg", :alt => "new_msx", :class => 'activity_icon')
    %input{:type => "checkbox", :class => "loc_activity_filter m_0", :value => 'new_msx'}
    %div
      %span Your scores
  %div
    =image_tag("icons/confirm_location.svg", :alt => "confirm_location", :class => 'activity_icon')
    %input{:type => "checkbox", :class => "loc_activity_filter m_0", :value => 'confirm_location'}
    %div
      %span Location confirmed
  %div
    =image_tag("icons/add_location.svg", :alt => "add_location", :class => 'activity_icon')
    %input{:type => "checkbox", :class => "loc_activity_filter m_0", :value => 'add_location'}
    %div
      %span Location added
%div{:style => "width: 100%; text-align: center; margin-bottom: 15px;"}
  %button.save_button.apply_location_activity_filters Apply Filters

%div.quick_button_content_header
  - if pagy.count == 0
    No recent location activity
  - else
    Showing #{pagy.from}-#{pagy.to} of #{pagy.count} location edits

= render 'shared/activity_item', show_location_link: false, page_activity: false

- if pagy.pages > 1
  #location_activity_pagination{:style => 'margin: 20px 10px; padding-bottom: 20px;'}
    != @pagy.series_nav()
