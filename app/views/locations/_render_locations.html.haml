- if @locations.size > 1
  #sort_controls
    - if @sort == 'machine_count'
      %button#sort_toggle_btn{onclick: "toggleSort();"} Sort by: A-Z
    - else
      %button#sort_toggle_btn{onclick: "toggleSort();"} Sort by: # of machines
- life_list_machine_ids = @locations.present? ? user_life_list_machine_ids : Set.new
- @locations.each do |l|
  %div.search_result[l]
    - if (@locations.size == 1 && @results_init == true)
      %div.location_detail
        = render :partial => 'locations/render_location_detail', :locals => {l: l}
    - else
      %div
        %div.sub_nav_location[l, :show_location_detail]{:onclick => "showLocationDetail(#{l.id});"}
          %div.name.bold.font22
            = l.name
          - if (l.state.blank?)
            %div.address
              %span.address_name[l, :location_summary] #{[l.street, l.city].join(', ')}
          - else
            %div.address
              %span.address_name[l, :location_summary] #{[l.street, l.city, l.state].join(', ')}
          %div.machine_names
            - l.machines.first(5).each do |machine|
              %div
                #{machine.name}
                %span.man_year (#{[machine.manufacturer, machine.year].reject(&:blank?).join(', ')})
          - if (l.machine_count > 5)
            %div.darkgrey.italic.pb_15
              plus
              = pluralize(l.machine_count - 5, 'more machine')
          - not_in_list_count = life_list_machine_ids.present? ? l.machines.count { |machine| !life_list_machine_ids.include?(machine.id) } : 0
          - show_distance = !@nearby_lat.blank?
          - show_location_type = l.location_type.present?
          - if show_distance || show_location_type || not_in_list_count > 0
            %div.location_meta_footer.darkgrey
              %div.location_meta_row
                - if show_location_type
                  %div.location_meta_item
                    - if l.location_type.icon.present?
                      =image_tag("icons/#{l.location_type.icon}.svg", :alt => l.location_type.icon)
                    %span= l.location_type.name
                - if show_distance
                  %div.location_meta_item
                    =image_tag("icons/compass.svg", :alt => "distance")
                    %span= "#{l.distance_from([@nearby_lat, @nearby_lon]).round(2)} mi"
                - if not_in_list_count > 0
                  %div.location_meta_item
                    =image_tag("icons/clipboard-list-outline-light.svg", :alt => "not in list")
                    %span
                      #{not_in_list_count} not in
                      = link_to 'list', profile_user_path(current_user.id, anchor: 'life_list_section'), onclick: "event.stopPropagation();"
- unless @locations.size == 0
  #next_link{:style => 'margin: 20px 10px'}
    != @pagy.series_nav() if @pagy.pages > 1
:javascript
  $("#next_link > nav > a").on("click", function(e) {
    $('#intro_container').css('display','none');
    e.preventDefault();

    results_init = false;
    var region_id = "#{@region&.id.to_i}";
    let url = new URL(e.target.href);

    topFunction();

    $.ajax({
      url: `${url}`,
      type: 'POST',
      data: { region_id, boundsData: boundsData, results_init, nearby_lat: nearbySearchActive ? center_lat : undefined, nearby_lon: nearbySearchActive ? center_lon : undefined },
      success: function(data) {
        $("#search_results").html(data);
      }
    });
    return false;
  });
