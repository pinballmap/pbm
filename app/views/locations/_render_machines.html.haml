- location_machine_xrefs.each do |lmx|
  %div[lmx, :machine]
    = render :partial => 'location_machine_xrefs/list_machine', :locals => {:lmx => lmx, :in_life_list => life_list_machine_ids.include?(lmx.machine_id)}
    .clear
    = render :partial => 'location_machine_xrefs/machine_tools', :locals => {:lmx => lmx}