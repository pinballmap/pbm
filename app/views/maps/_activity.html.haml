%div#map_activity.mt_20.mb_20.pt_10
  %div.bold.flex_center{:style => 'margin: 12px;'}
    %span.sorted_submissions
      - if pagy.count == 0
        No recent edits within the map view
      - else
        Showing #{pagy.from}-#{pagy.to} of #{pagy.count} recent edits within the map view
    %button#map_activity_filter_modal_button.filter_button{:type => "button", :style => "margin: 0 10px;", :onclick => "showActivityFilterModal('map_activity_filter_modal');"}
      %svg{xmlns: "http://www.w3.org/2000/svg", viewBox: "0 0 20 20", fill: "currentColor", "aria-hidden": "true"}
        %path{d: "M5 1.6c0-.553-.448-.6-1-.6-.553 0-1 .047-1 .6V10h2V1.6zM3 18.4c0 .551.447.6 1 .6.552 0 1-.049 1-.6V15H3v3.4zM6.399 11h-4.8C1.046 11 1 11.448 1 12v1c0 .553.046 1 .599 1H6.4c.55 0 .6-.447.6-1v-1c0-.552-.05-1-.601-1zm12 1h-4.801c-.552 0-.598.448-.598 1v1c0 .553.046 1 .599 1H18.4c.55 0 .6-.447.6-1v-1c0-.552-.05-1-.601-1zM13 7c0-.552-.05-1-.601-1h-4.8C7.046 6 7 6.448 7 7v1c0 .553.046 1 .599 1H12.4c.55 0 .6-.447.6-1V7zm-2-5.4c0-.553-.448-.6-1-.6-.553 0-1 .047-1 .6V5h2V1.6zM9 18.4c0 .551.447.6 1 .6.552 0 1-.049 1-.6V10H9v8.4zm8-16.8c0-.553-.448-.6-1-.6-.553 0-1 .047-1 .6V11h2V1.6zm-2 16.8c0 .551.447.6 1 .6.552 0 1-.049 1-.6V16h-2v2.4z"}
      Filter
    %span.close_activity.pointer{:onclick => "closeActivity();"}
      X

  = render 'shared/activity_filter_modal', modal_id: "map_activity_filter_modal", checkbox_class: "map_activity_filter m_0", apply_button_classes: "apply_map_activity_filters"

  = render 'shared/activity_item', show_location_link: true, page_activity: false

  - if pagy.pages > 1
    #next_link{:style => 'margin: 20px 10px; padding-bottom: 20px;'}
      != @pagy.series_nav()

:javascript
  $(document).trigger('activity-loaded');
  $('#map_activity_container .activity_filter_btn').each(function() {
    $(this).toggleClass('is-selected', $(this).find('input[type="checkbox"]')[0].checked);
  });
