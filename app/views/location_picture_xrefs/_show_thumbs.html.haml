- location_picture_xrefs.includes(photo_attachment: :blob).order(id: :desc).each do |lpx|
  - if lpx.photo.attached?
    - delete_title = user_signed_in? ? "<button class='lb-delete-btn' data-lpx-id='#{lpx.id}'>Remove this photo</button>" : ""
    = link_to image_tag(lpx.photo.variant(resize_to_limit: [240,240])), lpx.photo.variant(resize_to_limit: [1200,1200]), :class => "location_thumb location_picture_xref_#{lpx.id}", :"data-lightbox" => "location_thumb", :"data-title" => delete_title
