#page_body.notbold
  .column_container
    .column.w_560
      %p.alert= @contact_thanks
      %p.center
        =image_tag 'PPM-Splash-200.png', :alt => 'Thanks'
      %p.center
        - if @region
          In 3 seconds we'll take you back to the
          =link_to "#{@region.full_name} Pinball Map", region_homepage_path
        - else
          In 3 seconds we'll take you back to the
          =link_to "Pinball Map home page", root_path

:javascript
  window.setTimeout(function(){ window.location.href = '#{@region ? region_homepage_path : root_path}' },3000);
