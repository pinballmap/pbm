#page_body
  .column_container
    .column.bg_vlightpurple.w_640
      %p.red.bold.p1 Recent Activity
      %p.center
        Here's a feed of edits to #{@region_fullname} Pinball Map going back to 2018/19-ish.
      %p.center
        The scores here will only show your own scores.
    .clear

    .column.w_640.activity_filter_container.bg_vlightpurple
      %p.red.bold.font18.center
        Filter Activity
      = form_tag activity_path, :method => 'get', id: 'activity_filter' do
        %label.activity_filter_btn
          =image_tag("icons/new_lmx.svg", :alt => "new_lmx", :class => 'activity_icon')
          %input{:type => "checkbox", :id => "filterNewLmx", :name => "filterActivity", :value => 'new_lmx', :checked => Array(params[:submission_type]).include?('new_lmx')}
          %span Machine added
        %label.activity_filter_btn
          =image_tag("icons/remove_machine.svg", :alt => "remove_machine", :class => 'activity_icon')
          %input{:type => "checkbox", :id => "filterRemoveMachine", :name => "filterActivity", :value => 'remove_machine', :checked => Array(params[:submission_type]).include?('remove_machine')}
          %span Machine removed
        %label.activity_filter_btn
          =image_tag("icons/new_condition.svg", :alt => "new_condition", :class => 'activity_icon')
          %input{:type => "checkbox", :id => "filterNewCondition", :name => "filterActivity", :value => 'new_condition', :checked => Array(params[:submission_type]).include?('new_condition')}
          %span New condition
        %label.activity_filter_btn
          =image_tag("icons/new_msx.svg", :alt => "new_msx", :class => 'activity_icon')
          %input{:type => "checkbox", :id => "filterNewMsx", :name => "filterActivity", :value => 'new_msx', :checked => Array(params[:submission_type]).include?('new_msx')}
          %span Your scores
        %label.activity_filter_btn
          =image_tag("icons/confirm_location.svg", :alt => "confirm_location", :class => 'activity_icon')
          %input{:type => "checkbox", :id => "filterConfirmLocation", :name => "filterActivity", :value => 'confirm_location', :checked => Array(params[:submission_type]).include?('confirm_location')}
          %span Location confirmed
        %label.activity_filter_btn
          =image_tag("icons/add_location.svg", :alt => "add_location", :class => 'activity_icon')
          %input{:type => "checkbox", :id => "filterAddLocation", :name => "filterActivity", :value => 'add_location', :checked => Array(params[:submission_type]).include?('add_location')}
          %span Location added
        - if user_signed_in?
          %label.activity_filter_btn
            =image_tag("icons/face-grin-beam-regular-full.svg", :alt => "your_activity", :class => 'activity_icon')
            %input{:type => "checkbox", :id => "filterYourActivity", :name => "filterActivity", :value => 'your_activity', :checked => Array(params[:submission_type]).include?('your_activity')}
            %span Your Activity
        = submit_tag 'Apply Filters', :class => "save_button apply_filter"

    #activity.column.w_640.center
      = render partial: 'shared/activity_item', :locals => {show_location_link: true, page_activity: true}

:javascript
  function syncFilterBtnState(checkbox) {
    $(checkbox).closest('.activity_filter_btn').toggleClass('is-selected', checkbox.checked);
  }
  $('.activity_filter_btn input[type=checkbox]').each(function() {
    syncFilterBtnState(this);
  }).on('change', function() {
    syncFilterBtnState(this);
  });

  window.addEventListener("popstate", function(e) {
    let url = new URL(e.target.location.href)
    let pagenum = ""
    if (url.searchParams.has("page")) {
      pagenum = `?page=${url.searchParams.get("page")}`
    }

    refreshActivityList(url, pagenum, true)
  });

  $('.save_button').on('click', function(e) {
    e.preventDefault();
    let url = new URL(window.location.href);
    refreshActivityList(url);
  });

  function refreshActivityList(url, pagenum = "", suppressHistory = false) {
    activityFilters = []
    $("input:checkbox[name=filterActivity]:checked").each(function () {
      activityFilters.push(this.value);
    });

    $("#activity").html(loadingHTML());

    $.ajax({
      url: `${url.pathname}${pagenum}`,
      type: 'POST',
      data: {
        submission_type: activityFilters
      },
      success: function(data) {
        $("#activity").html(data);

        if (!suppressHistory) {
          window.history.pushState({"page": pagenum}, "", `${url.pathname}${pagenum}`)
        }
      }
    });
    return false;
  };
